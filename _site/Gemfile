# frozen_string_literal: true

# 指定 gem 的下载源
source "https://gems.ruby-china.com"


# 指定 Jekyll 版本。如果你不确定，可以先只写 gem "jekyll"
gem "jekyll"

# 如果你使用 GitHub Pages，推荐使用这个 gem，它会帮你管理所有相关的依赖
# 你的项目目录名是 "JanusVLN.github.io"，很可能就是这种情况
gem "github-pages", group: :jekyll_plugins

# 这里可以添加你项目使用的主题 gem，请查看 _config.yml 文件中的 "theme:" 配置项
# 例如，如果你的主题是 minima，就添加下面这行
# gem "minima", "~> 2.5"
